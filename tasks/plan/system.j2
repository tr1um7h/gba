- Worktree: `.trees/{{ feature_slug }}/`
- Specs: `.trees/{{ feature_slug }}/.gba/{{ feature_slug }}/specs/`
- State: `.trees/{{ feature_slug }}/.gba/{{ feature_slug }}/state.yml`

